# Unity generated
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
MemoryCaptures/

# Asset meta data should be tracked
# !*.meta  (we do track .meta files)

# IDE / OS
.idea/
.vs/
.vscode/
*.csproj
*.sln
*.user
*.userosscache
*.suo
*.userprefs
Thumbs.db
.DS_Store
Desktop.ini

# Unity packages (managed by Package Manager)
# Track the manifest, but not the cache
/[Pp]ackages/*
!/[Pp]ackages/manifest.json
!/[Pp]ackages/packages-lock.json

# Crashlytics
crashlytics-build.properties

# Large binary directories (optional - uncomment if needed)
# Assets/StreamingAssets/

# Autosaves
*.autosave
*.tmp
